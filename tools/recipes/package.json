{
  "name": "@sm-lab/recipes",
  "version": "0.1.0",
  "type": "module",
  "description": "TypeScript recipes to prepare CSM on-chain state on an anvil fork (rewritten fork.just; no Foundry)",
  "license": "MIT",
  "keywords": [
    "csm",
    "lido",
    "anvil",
    "fork",
    "recipes",
    "viem",
    "testing"
  ],
  "types": "./dist/index.d.mts",
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "import": "./dist/index.mjs"
    },
    "./cm": {
      "types": "./dist/cm.d.mts",
      "import": "./dist/cm.mjs"
    },
    "./csm": {
      "types": "./dist/csm.d.mts",
      "import": "./dist/csm.mjs"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "bin": {
    "sm-recipes": "dist/cli.mjs"
  },
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "start": "node dist/cli.mjs",
    "test": "vitest run",
    "types": "tsc --noEmit"
  },
  "dependencies": {
    "@sm-lab/keys": "workspace:*",
    "@sm-lab/merkle": "workspace:*",
    "@sm-lab/receipts": "workspace:*",
    "commander": "catalog:",
    "dotenv": "catalog:",
    "viem": "catalog:"
  },
  "devDependencies": {
    "@sm-lab/config": "workspace:*",
    "tsdown": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:",
    "@types/node": "catalog:"
  },
  "engines": {
    "node": ">=24"
  }
}
