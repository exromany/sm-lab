# Copy to .env (git-ignored) and fill in. Consumed by maintainer scripts via dotenv.
#
# Where each var is read matters: LIBRARY vars are read inside importable code, so they
# affect ANY script importing the package unless explicit options are passed; CLI-only
# vars are flag fallbacks read by a bin's commander wiring (or a run-and-exit script).

# ─── @sm-lab/receipts — protocol-address enrichment (scripts/refresh.ts) ─────
# Script-entry only: read by the human-run refresh.ts, never by the published package.
# Resolution order: --rpc flag > <CHAIN>_RPC_URL > ETH_RPC_URL. Without one,
# `pnpm --filter @sm-lab/receipts refresh ...` skips enrichment (and keeps any prior block).
HOODI_RPC_URL=
MAINNET_RPC_URL=
# Fallback used for any chain when the <CHAIN>_RPC_URL above is unset.
ETH_RPC_URL=

# ─── @sm-lab/recipes — fork-state recipe engine ──────────────────────────────
# CLI-only: RPC_URL / CL_MOCK_URL are sm-recipes flag fallbacks (src/cli/define.ts);
# the importable connect() reads no env — rpcUrl/clMockUrl arrive via ConnectOptions.
# Anvil JSON-RPC endpoint. Defaults to http://127.0.0.1:8545 when unset.
RPC_URL=
# cl-mock base URL used by clActivate. Point at the running sm-cl server (default 127.0.0.1:5052).
CL_MOCK_URL=
# LIBRARY (via merkle): the rewards / set-gate flows pin through @sm-lab/merkle, which
# reads IPFS_API_URL + PINATA_* inside the importable library — see the merkle section.
IPFS_API_URL=
PINATA_API_KEY=
PINATA_API_SECRET=
PINATA_JWT=
# TEST-ONLY: gates the opt-in Anvil fork smoke test. Must be a real archival RPC URL.
# Leave unset to skip the fork smoke; it is never required for the unit-test suite.
ANVIL_FORK_URL=

# ─── @sm-lab/anvil (`npx @sm-lab/anvil` / bin sm-anvil) ──────────────────────
# Boots anvil forking mainnet with the baked SM upgrade state overlaid.
# Needs a mainnet *archive* RPC able to serve block 25523407; resolution order is
# MAINNET_RPC_URL > ANVIL_FORK_URL > ETH_RPC_URL (all defined above). Optional
# ANVIL_FORK_BLOCK / ANVIL_STATE_FILE override the pinned block / state path.

# ─── @sm-lab/merkle — Merkle-tree builder and IPFS pinner ────────────────────
# LIBRARY: read inside src/ipfs.ts at call time, so they affect any script importing
# @sm-lab/merkle (and the recipes rewards flow) unless explicit apiUrl/noUpload options
# are passed. Unset IPFS_API_URL = local @sm-lab/ipfs (http://127.0.0.1:5001); real
# Pinata is used only when the PINATA_* creds are set. (Same variables as recipes above.)
IPFS_API_URL=
PINATA_API_KEY=
PINATA_API_SECRET=
PINATA_JWT=

# ─── @sm-lab/cl — consensus-layer mock service ───────────────────────────────
# CLI-only: all three are sm-cl flag fallbacks (client target / serve options).
# Base URL the sm-cl client points at for status/query/config calls (server default 127.0.0.1:5052).
CL_MOCK_URL=
# `sm-cl serve --state <file>` persistence target (state loads on boot, saves on shutdown).
CL_MOCK_STATE=
# `sm-cl serve --upstream <url>` — a real CL/beacon API to proxy-and-cache on a cache miss.
CL_UPSTREAM_URL=

# ─── @sm-lab/ipfs — IPFS mock service ────────────────────────────────────────
# CLI-only: base URL the sm-ipfs client points at (default http://127.0.0.1:5001).
IPFS_MOCK_URL=
# LIBRARY: read by @sm-lab/ipfs createApp when no gateway option is injected — the
# upstream IPFS gateway the mock proxies reads to when an object is not cached locally.
IPFS_UPSTREAM_GATEWAY=
# CLI-only: `sm-ipfs serve --state <file>` persistence target (loads on boot, saves on shutdown).
IPFS_MOCK_STATE=
