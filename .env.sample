# Copy to .env (git-ignored) and fill in. Consumed by maintainer scripts via dotenv.
#
# @sm-lab/receipts — protocol-address enrichment (scripts/refresh.ts).
# Resolution order: --rpc flag > <CHAIN>_RPC_URL > ETH_RPC_URL. Without one,
# `pnpm --filter @sm-lab/receipts refresh ...` skips enrichment (and keeps any prior block).
HOODI_RPC_URL=
MAINNET_RPC_URL=
# Fallback used for any chain when the <CHAIN>_RPC_URL above is unset.
ETH_RPC_URL=
