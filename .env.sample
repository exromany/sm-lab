# Copy to .env (git-ignored) and fill in. Consumed by maintainer scripts via dotenv.

# ─── @csm-lab/receipts — protocol-address enrichment (scripts/refresh.ts) ────
# Resolution order: --rpc flag > <CHAIN>_RPC_URL > ETH_RPC_URL. Without one,
# `pnpm --filter @csm-lab/receipts refresh ...` skips enrichment (and keeps any prior block).
HOODI_RPC_URL=
MAINNET_RPC_URL=
# Fallback used for any chain when the <CHAIN>_RPC_URL above is unset.
ETH_RPC_URL=

# ─── @csm-lab/recipes — fork-state recipe engine ─────────────────────────────
# Anvil JSON-RPC endpoint. Defaults to http://127.0.0.1:8545 when unset.
RPC_URL=
# cl-mock base URL used by clActivate. Defaults to http://127.0.0.1:3000 when unset.
CL_MOCK_URL=
# IPFS API endpoint for pinning (shared with merkle). Unset = real Pinata; point at
# a local @csm-lab/ipfs-mock instance for offline use: http://127.0.0.1:5001
IPFS_API_URL=
# Pinata credentials (shared with merkle — set in one place, used by both).
PINATA_API_KEY=
PINATA_API_SECRET=
PINATA_JWT=
# TEST-ONLY: gates the opt-in Anvil fork smoke test. Must be a real archival RPC URL.
# Leave unset to skip the fork smoke; it is never required for the unit-test suite.
ANVIL_FORK_URL=

# ─── @csm-lab/merkle — Merkle-tree builder and IPFS pinner ───────────────────
# IPFS API endpoint. Unset = real Pinata (uses PINATA_* below). Point at a local
# @csm-lab/ipfs-mock for offline/CI use: http://127.0.0.1:5001
IPFS_API_URL=
PINATA_API_KEY=
PINATA_API_SECRET=
PINATA_JWT=

# ─── @csm-lab/cl-mock — consensus-layer mock service (client side) ────────────
# Base URL the CL-mock client points at for status/query/config calls.
CL_MOCK_URL=

# ─── @csm-lab/ipfs-mock — IPFS mock service ──────────────────────────────────
# Base URL for the ipfs-mock server itself (used by health checks or consumers
# that need to override the default http://127.0.0.1:5001).
IPFS_MOCK_URL=
# Upstream IPFS gateway the mock proxies reads to when an object is not cached locally.
IPFS_UPSTREAM_GATEWAY=
