{
  "name": "@sm-lab/receipts",
  "version": "0.0.0",
  "type": "module",
  "description": "Versioned CSM anvil/deploy receipts — typed, importable contract addresses & ABIs",
  "license": "MIT",
  "keywords": [
    "csm",
    "lido",
    "anvil",
    "deploy",
    "receipts",
    "fixtures",
    "testing"
  ],
  "types": "./dist/index.d.mts",
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "import": "./dist/index.mjs",
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./data/*": "./data/*"
  },
  "files": [
    "dist",
    "data",
    "README.md"
  ],
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "test": "vitest run",
    "types": "tsc --noEmit",
    "refresh": "node --import tsx scripts/refresh.ts"
  },
  "devDependencies": {
    "@sm-lab/config": "workspace:*",
    "dotenv": "catalog:",
    "tsdown": "catalog:",
    "tsx": "catalog:",
    "typescript": "catalog:",
    "viem": "catalog:",
    "vitest": "catalog:",
    "@types/node": "catalog:"
  },
  "engines": {
    "node": ">=20"
  }
}
