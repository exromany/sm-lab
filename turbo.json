{
  "$schema": "https://turbo.build/schema.json",
  "ui": "tui",
  "tasks": {
    "build": {
      "dependsOn": ["^build", "generate"],
      "outputs": ["dist/**"]
    },
    "types": {
      "dependsOn": ["^build", "generate"],
      "outputs": ["dist/**/*.d.ts"]
    },
    "test": {
      "dependsOn": ["^build", "generate"],
      "outputs": ["coverage/**"]
    },
    "generate": {
      "inputs": ["prisma/schema.prisma"],
      "outputs": ["src/generated/**"]
    },
    "lint": {},
    "dev": {
      "cache": false,
      "persistent": true
    }
  }
}
