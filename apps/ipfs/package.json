{
  "name": "@sm-lab/ipfs",
  "version": "1.0.0",
  "type": "module",
  "description": "Pinata-compatible IPFS pinning + gateway emulator with deterministic CIDs, for CSM testing",
  "license": "MIT",
  "keywords": [
    "ipfs",
    "pinata",
    "mock",
    "csm",
    "lido",
    "testing",
    "cid",
    "gateway"
  ],
  "bin": {
    "sm-ipfs": "dist/cli.mjs"
  },
  "types": "./dist/index.d.mts",
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "import": "./dist/index.mjs"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "test": "vitest run",
    "types": "tsc --noEmit",
    "start": "node dist/cli.mjs serve"
  },
  "dependencies": {
    "@hono/node-server": "catalog:",
    "@sm-lab/core": "workspace:*",
    "commander": "catalog:",
    "hono": "catalog:",
    "multiformats": "^14.0.3"
  },
  "devDependencies": {
    "@sm-lab/config": "workspace:*",
    "@types/node": "catalog:",
    "tsdown": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  },
  "engines": {
    "node": ">=24"
  }
}
